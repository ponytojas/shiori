# Base URL for the Shiori API.
# In local development this is used as the Vite proxy target for /api requests.
VITE_API_BASE_URL=http://localhost:18080

# Optional control header required by backend in this project.
VITE_API_CONTROL_HEADER_NAME=x-shiori-token
VITE_API_CONTROL_HEADER_VALUE=34cb5b26d2af8d55c50e46abf346019f
