# Base URL for the Shiori API.
# In local development this is used as the Vite proxy target for /api requests.
VITE_API_BASE_URL=http://localhost:18080

# Optional: include an additional control header on every API request.
# Set both values together, or leave both unset.
VITE_API_CONTROL_HEADER_NAME=
VITE_API_CONTROL_HEADER_VALUE=
